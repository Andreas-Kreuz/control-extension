{
  "name": "@ak/root",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "yarn run check && node ./scripts/build-release.mjs",
    "ce-help": "node ./scripts/ce-help.mjs",
    "check": "yarn run check-lua && yarn run check-e2e && yarn run check-doc",
    "check-doc": "bundle exec jekyll build",
    "check-e2e": "yarn workspace @ak/web-app run cy-tests-run-headless",
    "check-lua": "luacheck -q --std max+busted lua/LUA && busted --output=plainTerminal --verbose --coverage --",
    "check-tools": "node ./scripts/check-tools.mjs",
    "dev-app": "yarn workspace @ak/web-app run start-playing",
    "dev-docs": "bundle exec jekyll serve",
    "format": "yarn run format-prettier && yarn run format-lua",
    "format-lua": "node ./scripts/format-lua-with-sumneko.mjs",
    "format-prettier": "prettier --write .",
    "play": "yarn workspace @ak/web-server run start-with-app",
    "rebuild-server": "yarn workspace @ak/web-server run build-app && yarn workspace @ak/web-server run copy-web-app",
    "sync-control-extension-version": "node ./scripts/sync-control-extension-version.mjs",
    "test-app": "yarn workspace @ak/web-app run cy-tests"
  },
  "packageManager": "yarn@4.9.1",
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/prettier": "^3.0.0"
  },
  "dependencies": {
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
