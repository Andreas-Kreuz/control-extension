{
  "name": "@ak/root",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "yarn workspace @ak/web-server run build",
    "build:release": "yarn run check && node ./scripts/build-release.mjs",
    "build:win": "yarn workspace @ak/web-server run package-win",
    "ce-help": "node ./scripts/ce-help.mjs",
    "check": "yarn run tools:check && yarn run lint && yarn run test",
    "dev:app": "yarn workspace @ak/web-app run start-playing",
    "dev:docs": "bundle exec jekyll serve",
    "dev:storybook": "yarn workspace @ak/web-app run storybook",
    "format": "yarn run format:apps && yarn run format:lua",
    "format:apps": "prettier --write .",
    "format:lua": "node ./scripts/format-lua-with-sumneko.mjs",
    "lint": "yarn run lint:lua && yarn run lint:server && yarn run lint:app && yarn run lint:shared",
    "lint:app": "yarn workspace @ak/web-app run lint",
    "lint:lua": "luacheck --config .luacheckrc lua/LUA",
    "lint:server": "yarn workspace @ak/web-server run lint",
    "lint:shared": "yarn workspace @ak/web-shared run lint",
    "run:app": "yarn run build && yarn workspace @ak/web-server run start-built",
    "sync-control-extension-version": "node ./scripts/sync-control-extension-version.mjs",
    "test": "yarn run test:lua && yarn run test:server && yarn run test:app && yarn run test:docs",
    "test:app": "yarn workspace @ak/web-app run cy-tests-run-headless",
    "test:app:ui": "yarn workspace @ak/web-app run cy-tests",
    "test:docs": "bundle exec jekyll build",
    "test:lua": "busted --config-file .busted --output=plainTerminal --verbose --",
    "test:lua:coverage": "busted --config-file .busted --output=plainTerminal --verbose --coverage --",
    "test:server": "yarn workspace @ak/web-server run build-shared && yarn workspace @ak/web-server exec tsc --build && yarn node ./scripts/run-server-tests.mjs",
    "tools:check": "node ./scripts/check-tools.mjs"
  },
  "packageManager": "yarn@4.9.1",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@types/eslint": "^9.6.1",
    "@types/prettier": "^3.0.0"
  },
  "dependencies": {
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
