allow_defined_top = true

-- See https://luacheck.readthedocs.io/en/stable/warnings.html
-- 121 - global assignment to readonly
-- 122 - global field assignment to readonly
-- 131 - global assignment
-- 212 - unused argument
-- 631 - line is too long
