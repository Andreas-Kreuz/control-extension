{
  "name": "@ce/web-server",
  "version": "0.0.4",
  "description": "Control Extension Server für EEP",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "build": "tsc --build",
    "build:app-assets": "node ../../scripts/copy-web-app.mjs",
    "clean": "node ../../scripts/clean-paths.mjs build dist target",
    "build:exe": "node ../../scripts/assert-build-win-supported.mjs && electron-builder build --win --x64",
    "build:dir": "electron-builder --dir",
    "build:dist": "electron-builder",
    "dev": "tsc && node ./build/server/app/HeadlessStart.js --allow-dev-origins",
    "dev:ts": "tsc -w",
    "lint": "eslint \"src/**/*.ts\"",
    "run": "electron ./build/main/index.js",
    "run:headless": "node ./build/server/app/HeadlessStart.js",
    "run:test": "node ../../scripts/prepare-cypress-io.mjs && tsc && node ./build/server/app/HeadlessStart.js --testmode --port 3001 --exchange-dir ../web-app/cypress/io --config-dir ../web-app/cypress/server-config",
    "tools:copy-app": "node ../../scripts/copy-web-app.mjs",
    "tools:persist-eep-state": "tsc && node ./build/server/eep/helpers/EepStateReader.js",
    "tools:sync-version": "node ../../scripts/sync-control-extension-version.mjs"
  },
  "repository": "https://github.com/Andreas-Kreuz/control-extension",
  "keywords": [
    "EEP",
    "Lua"
  ],
  "main": "./build/main/index.js",
  "build": {
    "electronVersion": "35.1.2",
    "appId": "io.github.andreas-kreuz.control-extention-for-eep",
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "mac": {
      "category": "Application"
    },
    "win": {
      "target": [
        "portable"
      ],
      "compression": "maximum",
      "artifactName": "control-extension-server.${ext}"
    }
  },
  "author": "Andreas-Kreuz",
  "license": "MIT",
  "devDependencies": {
    "@types/command-line-args": "^5.2.3",
    "@types/command-line-usage": "^5.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/tail": "^2.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "del-cli": "^7.0.0",
    "electron": "^41.0.3",
    "electron-builder": "26.8.1",
    "eslint": "^10.0.3",
    "npm-run-all": "^4.1.5",
    "run-script-os": "^1.1.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ce/web-shared": "workspace:^",
    "@electron/typescript-definitions": "^9.1.5",
    "command-line-args": "^6.0.1",
    "command-line-usage": "^7.0.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "tail": "^2.2.6"
  }
}
