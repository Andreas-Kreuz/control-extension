{
  "name": "@ce/web-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "homepage": ".",
  "scripts": {
    "clean": "node ../../scripts/clean-paths.mjs dist cypress/screenshots cypress/videos cypress/io coverage storybook-static",
    "dev": "yarn vite --host --configLoader native",
    "build": "yarn vite build --configLoader native",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "run": "vite preview --configLoader native",
    "dev:storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "test:e2e": "node ../../scripts/run-cypress.mjs run",
    "test:e2e:ui": "node ../../scripts/run-cypress.mjs open",
    "test:e2e:headed": "node ../../scripts/run-cypress.mjs run --headed",
    "test:e2e:log": "node ../../scripts/run-cypress.mjs run --headed --spec cypress/e2e/modules/log/log_spec.cy.ts",
    "test:smoke": "node ../../scripts/local-headless-smoke.mjs",
    "tools:cypress:open": "node ../../scripts/run-cypress.mjs open",
    "tools:cypress:run": "node ../../scripts/run-cypress.mjs run",
    "tools:sync-version": "node ../../scripts/sync-control-extension-version.mjs"
  },
  "dependencies": {
    "@ce/web-shared": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/anek-latin": "^5.2.7",
    "@fontsource/material-icons": "^5.2.7",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@testing-library/dom": "^10.4.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.3",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@storybook/addon-onboarding": "^10.3.1",
    "@storybook/addon-themes": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/react": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "cypress": "^15.12.0",
    "playwright": "^1.58.2",
    "storybook": "^10.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
